# StockLens Backend — Environment Variables
# Copy this file to .env and fill in your values.
# All values shown are safe defaults for local development.

# Database
DATABASE_URL=postgresql+asyncpg://stocklens:stocklens@postgres:5432/stocklens
TEST_DATABASE_URL=postgresql+asyncpg://stocklens:stocklens@postgres_test:5432/stocklens_test

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-256-bit-key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS
AWS_REGION=eu-west-2

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# OCR
OCR_TESSERACT_CMD=

# Rate Limiting
RATE_LIMIT_LOGIN=20/minute
RATE_LIMIT_DEFAULT=100/minute

# Logging
STRUCTLOG_LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development
