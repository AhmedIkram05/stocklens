# Airflow development environment template
# Copy to .env and fill in values for local development.
# Production: set via EC2 environment or AWS Secrets Manager.

AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
DATABASE_URL=postgresql+asyncpg://stocklens:stocklens@postgres:5432/stocklens
MLFLOW_TRACKING_URI=http://mlflow:5001
MODEL_ARTIFACT_DIR=/model_artifacts/champion
AWS_REGION=eu-west-2
ENVIRONMENT=development
